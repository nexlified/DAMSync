# Server
DAM_SERVER_HOST=0.0.0.0
DAM_SERVER_PORT=8080
DAM_SERVER_READ_TIMEOUT=30s
DAM_SERVER_WRITE_TIMEOUT=30s
DAM_SERVER_CDN_BASE_URL=http://localhost:8080
DAM_ENV=development

# Database
DAM_DATABASE_DSN=postgres://dam:dam_secret@localhost:5432/dam?sslmode=disable
DAM_DATABASE_MAX_OPEN_CONNS=25
DAM_DATABASE_MAX_IDLE_CONNS=5

# Redis
DAM_REDIS_ADDR=localhost:6379
DAM_REDIS_PASSWORD=
DAM_REDIS_DB=0

# S3 / Object Storage
DAM_STORAGE_ENDPOINT=http://localhost:9000
DAM_STORAGE_REGION=us-east-1
DAM_STORAGE_BUCKET=dam-assets
DAM_STORAGE_ACCESS_KEY=minioadmin
DAM_STORAGE_SECRET_KEY=minioadmin123
DAM_STORAGE_USE_PATH_STYLE=true

# JWT
DAM_JWT_ACCESS_SECRET=change-me-access-secret-32-chars-min
DAM_JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars-min
DAM_JWT_ACCESS_TTL=15m
DAM_JWT_REFRESH_TTL=168h

# Migrations
DAM_MIGRATIONS_PATH=migrations

# ACME / TLS (production)
DAM_ACME_EMAIL=admin@example.com
DAM_ACME_ENABLED=false

# Logging
DAM_LOG_LEVEL=debug
DAM_LOG_FORMAT=pretty

# CORS (comma-separated allowed origins; leave empty to disable)
DAM_CORS_ALLOW_ORIGINS=http://localhost:5173
